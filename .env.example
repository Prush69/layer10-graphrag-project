# Required: Your FREE Groq API Key
# Get one at https://console.groq.com/keys
GROQ_API_KEY=gsk_your_groq_api_key_here

# Optional: GitHub token for higher rate limits (unauthenticated = 60 req/hr)
# Create at https://github.com/settings/tokens (no scopes needed for public repos)
GITHUB_TOKEN=your_github_personal_access_token_here

# Neo4j AuraDB (Copy-paste from your Aura Dashboard)
NEO4J_URI=neo4j+s://your-instance.databases.neo4j.io
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=your_password_here
